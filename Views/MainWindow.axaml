<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ExifEditor.ViewModels"
        xmlns:models="using:ExifEditor.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:DataType="vm:MainWindowViewModel"
        x:Class="ExifEditor.Views.MainWindow"
        Title="ExifEditor"
        Icon="/Resources/icon.png"
        Background="{DynamicResource BgPrimaryBrush}">
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="{DynamicResource BgSecondaryBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Folder..." Command="{Binding SelectDirectoryCommand}"/>
                <Separator/>
                <MenuItem Header="_Exit" Command="{Binding ExitApplicationCommand}"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Generate PDF Report" Command="{Binding GeneratePDFReportCommand}"/>
                <Separator/>
                <MenuItem Header="Theme: Ocean Blue" Command="{Binding SwitchToOceanBlueCommand}"/>
                <MenuItem Header="Theme: Violet Cyan" Command="{Binding SwitchToVioletCyanCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Bottom" Margin="10" Background="{DynamicResource BgPrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Directory path bar -->
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                       VerticalAlignment="Center"
                       Text="{Binding DirPath}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <Button Grid.Row="0" Grid.Column="3"
                    Classes="accent"
                    Content="Select Directory"
                    Command="{Binding SelectDirectoryCommand}"
                    VerticalAlignment="Center" HorizontalAlignment="Right"/>

            <!-- Progress bar -->
            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                         Classes="themed"
                         IsVisible="{Binding IsLoading}"
                         Minimum="0" Maximum="{Binding LoadingTotal}"
                         Value="{Binding LoadingProgress}"
                         Height="3"/>

            <!-- Image list -->
            <ListBox Classes="themed"
                     ItemsSource="{Binding Images}"
                     SelectedItem="{Binding SelectedImage}"
                     Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="BorderThickness" Value="0 0 0 1"/>
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <Border DockPanel.Dock="Top" CornerRadius="{DynamicResource SmallRadius}" ClipToBounds="True">
                                <Image Source="{Binding Thumbnail}" Width="200" Height="100"/>
                            </Border>
                            <TextBlock Text="{Binding Title}"
                                       VerticalAlignment="Bottom"
                                       Margin="0 6 0 0"
                                       DockPanel.Dock="Bottom"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="12"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Details panel -->
            <Border Classes="card"
                    Grid.Row="2" Grid.Column="2"
                    Margin="8 0 0 0">
                <Grid DataContext="{Binding SelectedImage}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*" MinHeight="200"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="44"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- File name row -->
                    <Label Grid.Row="0" Grid.Column="0" Classes="heading" Content="File Name:"/>
                    <Label Grid.Row="0" Grid.Column="1"
                           Content="{Binding FileName}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Button Grid.Row="0" Grid.Column="1"
                            Classes="subtle"
                            Content="Show"
                            HorizontalAlignment="Right"
                            Command="{Binding ShowFullImageCommand}"
                            Padding="10,4"/>

                    <!-- Image preview + properties -->
                    <DockPanel Grid.Row="1" Grid.Column="1">
                        <ListBox Classes="themed" DockPanel.Dock="Right"
                                 HorizontalAlignment="Right" Margin="8 0 0 0"
                                 ItemsSource="{Binding ImageProperties}" MaxWidth="200"/>
                        <Border CornerRadius="{DynamicResource MediumRadius}" ClipToBounds="True"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="0 0 0 0">
                            <Panel Name="ImageTagPanel" Background="Transparent"
                                   PointerPressed="OnImagePointerPressed"
                                   PointerMoved="OnImagePointerMoved"
                                   PointerReleased="OnImagePointerReleased"
                                   PointerWheelChanged="OnImagePointerWheelChanged"
                                   ClipToBounds="True">
                                <Panel Name="ZoomableContent">
                                    <Image Name="PreviewImage" Source="{Binding LargerThumbnail}" Stretch="Uniform"/>
                                    <Canvas Name="TagCanvas"/>
                                </Panel>
                                <Border Background="{DynamicResource TagLabelBgBrush}"
                                        CornerRadius="4" Padding="4 2"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="4" IsHitTestVisible="False"
                                        Name="ZoomIndicator" IsVisible="False">
                                    <TextBlock Name="ZoomText" Foreground="White" FontSize="10"/>
                                </Border>
                            </Panel>
                        </Border>
                    </DockPanel>

                    <!-- Artist row -->
                    <Label Grid.Row="2" Grid.Column="0" Classes="heading" Content="Artist:" VerticalAlignment="Center" Margin="0 8 0 0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Classes="themed"
                             Text="{Binding Artist}" Margin="0 8 0 0"/>

                    <!-- Scanned row -->
                    <Label Grid.Row="3" Grid.Column="0" Classes="heading"
                           Content="Scanned:" VerticalAlignment="Center" Margin="0 8 0 0"/>
                    <DockPanel Grid.Row="3" Grid.Column="1" Margin="0 8 0 0">
                        <Button Classes="subtle" Content="Use Recent"
                                Padding="10 5" Margin="5 0 0 0"
                                Command="{Binding UseRecentScannedCommand}" DockPanel.Dock="Right"/>
                        <TextBox Classes="themed" Text="{Binding Scanned}" HorizontalAlignment="Stretch"/>
                    </DockPanel>

                    <!-- Tags section -->
                    <Label Grid.Row="4" Grid.Column="0" Classes="heading"
                           Content="Tags:" VerticalAlignment="Top" Margin="0 8 0 0"/>
                    <DockPanel Grid.Row="4" Grid.Column="1" Margin="0 8 0 0">
                        <DockPanel DockPanel.Dock="Bottom" Margin="0 4 0 0">
                            <CheckBox Name="ShowAllTagsCheckBox" Content="Show all tags"
                                      FontSize="11" IsChecked="True"
                                      DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10 0 0 0"
                                      Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Click on the image to add a tag" FontSize="10"
                                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <ListBox x:Name="TagsList" Classes="themed"
                                 ItemsSource="{Binding Tags}" MaxHeight="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:ImageTag">
                                    <DockPanel>
                                        <Button Classes="danger" Content="✕"
                                                DockPanel.Dock="Right" Padding="5 2" Margin="5 0 0 0"
                                                Command="{ReflectionBinding #TagsList.DataContext.RemoveTagCommand}"
                                                CommandParameter="{Binding}"/>
                                        <Button Classes="subtle" Content="✎"
                                                DockPanel.Dock="Right" Padding="5 2" Margin="5 0 0 0"
                                                Command="{ReflectionBinding #TagsList.DataContext.EditTagCommand}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding PositionDisplay}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="10" Margin="10 0 0 0" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Description -->
                    <Label Grid.Row="5" Grid.Column="0" Classes="heading"
                           Content="Description:" Margin="0 8 0 0" VerticalAlignment="Top"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Classes="themed"
                             Text="{Binding Description}" TextWrapping="Wrap"
                             Margin="0 8 0 0" AcceptsReturn="True"
                             MinHeight="60" MaxHeight="80" VerticalAlignment="Top"/>

                    <!-- Save button -->
                    <Button Grid.Row="6" Grid.Column="1" Classes="success"
                            Content="Save" Padding="16 7" Margin="0 8 0 0"
                            IsEnabled="{Binding IsModified}"
                            Command="{Binding SaveCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
