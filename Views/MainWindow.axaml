<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ExifEditor.ViewModels"
        xmlns:models="using:ExifEditor.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:DataType="vm:MainWindowViewModel"
        x:Class="ExifEditor.Views.MainWindow"
        Title="ExifEditor">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Folder..." Command="{Binding SelectDirectoryCommand}"/>
                <Separator/>
                <MenuItem Header="_Exit" Command="{Binding ExitApplicationCommand}"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Generate PDF Report" Command="{Binding GeneratePDFReportCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>
        <Grid DockPanel.Dock="Bottom" Margin="10" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center" Text="{Binding DirPath}"/>
            <Button Grid.Row="0" Grid.Column="3" Content="Select Directory" Background="Orange" Command="{Binding SelectDirectoryCommand }" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                         IsVisible="{Binding IsLoading}"
                         Minimum="0" Maximum="{Binding LoadingTotal}"
                         Value="{Binding LoadingProgress}"
                         Height="3"/>
            <ListBox ItemsSource="{Binding Images}" SelectedItem="{Binding SelectedImage}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">   
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="BorderThickness" Value="0 1 0 0" />
                        <Setter Property="Padding" Value="5" />
                        <Setter Property="BorderBrush" Value="black" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <Image Source="{Binding Thumbnail}" Width="200" Height="100" DockPanel.Dock="Top" />
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Bottom" Margin="0 5 0 0"  DockPanel.Dock="Bottom"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border
            BorderBrush="DarkGray"
            BorderThickness="0 0 0 0"
            Grid.Row="2"
            Grid.Column="2" 
            Margin="5"
            Padding="15">
            <Grid DataContext="{Binding SelectedImage}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" FontWeight="Bold" Content="File Name:"/>
                <Label Grid.Row="0" Grid.Column="1" Content="{Binding FileName}"/>
                <Button Grid.Row="0" Grid.Column="1" Content="Show" HorizontalAlignment="Right" Command="{Binding ShowFullImageCommand}"/>
                <DockPanel Grid.Row="1" Grid.Column="1" Height="300">
                    <ListBox DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="5 0 0 0" ItemsSource="{Binding ImageProperties}" MaxWidth="200"/>
                    <Panel Name="ImageTagPanel" Margin="5" Cursor="Cross" Background="Transparent" PointerPressed="OnImagePointerPressed" ClipToBounds="True">
                        <Image Name="PreviewImage" Source="{Binding LargerThumbnail}" Stretch="Uniform"/>
                        <Canvas Name="TagCanvas"/>
                    </Panel>
                </DockPanel>
                <Label Grid.Row="2" Grid.Column="0" FontWeight="Bold" Content="Artist:" VerticalAlignment="Center"/>
                <DockPanel Grid.Row="2" Grid.Column="1">
                    <Button Content="Edit Default Artist" Background="Orange" Padding="10 5" Margin="5 0 0 0" Command="{Binding EditDefaultArtistCommand}" DockPanel.Dock="Right"/>
                    <Button Content="Use Default Artist" Background="Orange" Padding="10 5" Margin="5 0 0 0" Command="{Binding UseDefaultArtistCommand }" DockPanel.Dock="Right"/>
                    <TextBox Text="{Binding Artist}" HorizontalAlignment="Stretch" />
                </DockPanel>
                <Label Grid.Row="3" Grid.Column="0" FontWeight="Bold" Content="Tags:" VerticalAlignment="Top" Margin="0 5 0 0"/>
                <DockPanel Grid.Row="3" Grid.Column="1" Margin="0 5 0 0">
                    <DockPanel DockPanel.Dock="Bottom" Margin="0 3 0 0">
                        <CheckBox Name="ShowAllTagsCheckBox" Content="Show all tags" FontSize="11" IsChecked="True"
                                  DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10 0 0 0"/>
                        <TextBlock Text="Click on the image to add a tag" FontSize="10" Foreground="Gray" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ListBox x:Name="TagsList" ItemsSource="{Binding Tags}" MaxHeight="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ImageTag">
                                <DockPanel>
                                    <Button Content="✕" DockPanel.Dock="Right" Padding="5 2" Margin="5 0 0 0"
                                            Command="{ReflectionBinding #TagsList.DataContext.RemoveTagCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="✎" DockPanel.Dock="Right" Padding="5 2" Margin="5 0 0 0"
                                            Command="{ReflectionBinding #TagsList.DataContext.EditTagCommand}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PositionDisplay}" Foreground="Gray" FontSize="10"
                                               Margin="10 0 0 0" VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
                <Label Grid.Row="4" Grid.Column="0" FontWeight="Bold" Content="Description:" Margin="0 5 0 0" VerticalAlignment="Top"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" Margin="0 5 0 0" AcceptsReturn="True"/>            
                <Button Grid.Row="5" Grid.Column="1" Content="Save" Background="Orange" Padding="10 5" Margin="0 5" IsEnabled="{Binding IsModified}" Command="{Binding SaveCommand }" HorizontalAlignment="Right"/>
            </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
