<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:ExifEditor.Services"
        x:Class="ExifEditor.Views.AddTagWindow"
        Title="Tag"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource BgPrimaryBrush}">
    <Grid Margin="20" MinWidth="320">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding EnterLabel, Source={x:Static svc:LocalizationService.Current}}"
                   Margin="0 0 0 8"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <AutoCompleteBox Grid.Row="1" Name="LabelBox"
                         Margin="0 0 0 14"
                         FilterMode="ContainsOrdinal"
                         MinimumPrefixLength="0"
                         MinimumPopulateDelay="0:0:0.05"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="accent" Content="{Binding Ok, Source={x:Static svc:LocalizationService.Current}}" Name="OkButton" Width="80"/>
            <Button Classes="subtle" Content="{Binding Cancel, Source={x:Static svc:LocalizationService.Current}}" Name="CancelButton" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
