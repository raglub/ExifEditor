<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ExifEditor.Views.ConfirmWindow"
        Title="Confirm"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource BgPrimaryBrush}">
    <Grid Margin="20" MinWidth="320">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Name="MessageText"
                   Margin="0 0 0 16"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="danger" Content="Yes" Name="YesButton" Width="80"/>
            <Button Classes="subtle" Content="No" Name="NoButton" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
