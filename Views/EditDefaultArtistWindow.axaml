<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ExifEditor.Views.EditDefaultArtistWindow"
        xmlns:vm="using:ExifEditor.ViewModels"
        x:DataType="vm:EditDefaultArtistViewModel"
        Title="Edit Default Artist"
        Background="{DynamicResource BgPrimaryBrush}">
    <Grid Margin="20" VerticalAlignment="Center" HorizontalAlignment="Stretch" MinWidth="300">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Classes="heading"
               Content="Artist:" Padding="5 6" Margin="0 0 10 0"/>
        <TextBox Grid.Row="0" Grid.Column="1" Classes="themed" Text="{Binding Artist}"/>
        <Button Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Classes="accent"
                Margin="0 12 0 0"
                Command="{Binding SaveFormCommand}"
                HorizontalAlignment="Center">Save</Button>
    </Grid>
</Window>
