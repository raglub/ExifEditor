<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Violet Cyan Dark Theme -->

    <!-- Backgrounds -->
    <Color x:Key="BgPrimaryColor">#13111C</Color>
    <Color x:Key="BgSecondaryColor">#1A1726</Color>
    <Color x:Key="SurfaceColor">#241F33</Color>
    <Color x:Key="SurfaceHoverColor">#2D2640</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#352E4A</Color>
    <Color x:Key="BorderSubtleColor">#241F33</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#EEEDF5</Color>
    <Color x:Key="TextSecondaryColor">#9A95B0</Color>
    <Color x:Key="TextMutedColor">#5C5675</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#7C3AED</Color>
    <Color x:Key="AccentHoverColor">#8B5CF6</Color>
    <Color x:Key="AccentPressedColor">#6D28D9</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#34D399</Color>
    <Color x:Key="DangerColor">#FB7185</Color>
    <Color x:Key="WarningColor">#FBBF24</Color>

    <!-- Tag Marker -->
    <Color x:Key="TagMarkerColor">#06B6D4</Color>
    <Color x:Key="TagMarkerStrokeColor">#EEEDF5</Color>
    <Color x:Key="TagLabelBgColor">#CC1A1726</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="TagMarkerBrush" Color="{StaticResource TagMarkerColor}"/>
    <SolidColorBrush x:Key="TagMarkerStrokeBrush" Color="{StaticResource TagMarkerStrokeColor}"/>
    <SolidColorBrush x:Key="TagLabelBgBrush" Color="{StaticResource TagLabelBgColor}"/>

    <!-- Corner Radius -->
    <CornerRadius x:Key="SmallRadius">4</CornerRadius>
    <CornerRadius x:Key="MediumRadius">6</CornerRadius>
    <CornerRadius x:Key="LargeRadius">8</CornerRadius>

    <!-- Theme metadata -->
    <x:String x:Key="ThemeName">Violet Cyan</x:String>

</ResourceDictionary>
